# SmartDOX Streamlit App - Environment Configuration
# 
# LOCAL DEVELOPMENT: Copy this file to .env and fill in your values
# STREAMLIT CLOUD: Add these in the Secrets section (Settings gear icon)
# RENDER: Add these in Environment Variables section
#

# Backend API URL
# Local: http://localhost:8000
# Render: https://smartdox-backend.onrender.com
# Other: Your backend URL here
API_BASE_URL=http://localhost:8000

# Optional: Add these if you have backend API authentication
# API_KEY=your_secret_api_key_here

# Optional: Groq API Key (if Streamlit processes documents directly)
# GROQ_API_KEY=your_groq_api_key_here

